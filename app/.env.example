# ============================================================
# ASL-3D — Modèle de configuration environment
# Copiez ce fichier vers .env et remplissez vos valeurs
# cp .env.example .env
# ============================================================

# DATABASE MySQL (XAMPP)
SECRET_KEY=votre_cle_secrete_flask
DB_URI=mysql+pymysql://root:VOTRE_MOT_DE_PASSE@localhost/asl3d_db

# GOOGLE OAuth2
# Créer sur: https://console.cloud.google.com → APIs → Credentials
# Redirect URI: http://127.0.0.1:5000/auth/google/callback
GOOGLE_CLIENT_ID=VOTRE_CLIENT_ID_GOOGLE
GOOGLE_CLIENT_SECRET=VOTRE_CLIENT_SECRET_GOOGLE

# GITHUB OAuth2
# Créer sur: https://github.com/settings/applications/new
# Callback URL: http://127.0.0.1:5000/auth/github/callback
GITHUB_CLIENT_ID=VOTRE_CLIENT_ID_GITHUB
GITHUB_CLIENT_SECRET=VOTRE_CLIENT_SECRET_GITHUB

# LOGICIELS LOCAUX (RECONSTRUCTION AVANCÉE)
COLMAP_PATH=C:/colmap-x64-windows-nocuda/COLMAP.bat
BLENDER_PATH=C:/Program Files/Blender Foundation/Blender 5.0/blender.exe

# COLMAP performance tuning
COLMAP_DOWNSCALE_MAX=1600
COLMAP_SIFT_MAX_FEATURES=4096
# Export GLB : centrage, suppression outliers (98 = garder 98%% des sommets proches du centre)
MESH_OUTLIER_PERCENTILE=98
MESH_TARGET_SIZE=2.0
MESH_DECIMATE_RATIO=0.6
COLMAP_NUM_THREADS=4
# Whether to use GPU for SIFT extraction/matching (0 = CPU, 1 = GPU). 
# Highly recommended to keep as 0 for background Windows tasks / CPU-only builds.
COLMAP_USE_GPU=0
COLMAP_MATCHER=auto
COLMAP_AUTO_MATCHER_THRESHOLD=200
COLMAP_EXHAUSTIVE_NUM_WORKERS=4
COLMAP_TIMEOUT=3600
COLMAP_RETRIES=2
# Texturing photogrammétrique (nécessite reconstruction dense réussie)
COLMAP_ENABLE_TEXTURE=1
COLMAP_TEXTURE_SCALE=1
# Flask : 0 = pas de rechargement auto (recommandé pendant une reconstruction COLMAP)
FLASK_USE_RELOADER=0
SFM_STALL_MINUTES=15

# Monitoring (Docker Compose : prometheus + loki + grafana + promtail)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Prometheus scrape : http://127.0.0.1:5000/metrics (app locale)
# Grafana : http://localhost:3000 | Prometheus : http://localhost:9090

